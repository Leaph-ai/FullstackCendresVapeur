# PostgreSQL (docker compose)
POSTGRES_USER=cendres
POSTGRES_PASSWORD=cendres
POSTGRES_DB=cendres_vapeur
POSTGRES_PORT=5432

# Connexion SQLAlchemy (hôte local quand l'API tourne hors conteneur)
DATABASE_URL=postgresql+psycopg://cendres:cendres@localhost:5432/cendres_vapeur

# Environnement : dev (2FA désactivée) | prod (2FA activée)
APP_ENV=dev

# Auth (voir ROADMAP.md)
JWT_SECRET=changez-moi-en-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# SMTP Google (mot de passe d'application : https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
CONTACT_ADMIN_EMAIL=
TWO_FACTOR_CODE_EXPIRE_MINUTES=10

ALLOWED_ORIGINS=http://localhost:5173
WS_HEARTBEAT_SECONDS=30

# Bourse du cuivre (simulateur SSE)
COPPER_BASE_INDEX=248
COPPER_MIN_INDEX=180
COPPER_MAX_INDEX=320
COPPER_TICK_SECONDS=3
COPPER_SPARK_LENGTH=14
COPPER_VOLATILITY=6

# OAuth – Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BACKEND_BASE_URL=http://localhost:8000
OAUTH_REDIRECT_BASE_URL=http://localhost:5173
